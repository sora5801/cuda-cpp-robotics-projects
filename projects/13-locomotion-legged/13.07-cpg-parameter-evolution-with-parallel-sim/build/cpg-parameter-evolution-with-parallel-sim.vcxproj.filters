<!-- ========================================================================
  cpg-parameter-evolution-with-parallel-sim.vcxproj.filters — Solution Explorer folder layout for
  13.07 (CPG (central pattern generator) parameter evolution with parallel sim)

  Filters are purely cosmetic: they group files into virtual folders inside
  Visual Studio's Solution Explorer and have zero effect on the build. The
  GUIDs below are the well-known standard filter identifiers VS generates;
  they are shared by convention across all C++ projects.
======================================================================== -->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <Filter Include="Source Files">
      <UniqueIdentifier>{4FC737F1-C7A5-4376-A066-2A32D752A2FF}</UniqueIdentifier>
      <Extensions>cpp;c;cc;cxx;cu</Extensions>
    </Filter>
    <Filter Include="Header Files">
      <UniqueIdentifier>{93995380-89BD-4b04-88EB-625FBE52EBFB}</UniqueIdentifier>
      <Extensions>h;hh;hpp;hxx;cuh</Extensions>
    </Filter>
  </ItemGroup>
  <ItemGroup>
    <CudaCompile Include="..\src\main.cu">
      <Filter>Source Files</Filter>
    </CudaCompile>
    <CudaCompile Include="..\src\kernels.cu">
      <Filter>Source Files</Filter>
    </CudaCompile>
    <ClCompile Include="..\src\reference_cpu.cpp">
