# .gitattributes — line-ending policy for a Windows-first, Linux-friendly repo.
#
# Why this file exists: the repository is authored on Windows (Visual Studio,
# PowerShell) but ships bash scripts (demo/run_demo.sh, scripts/download_data.sh)
# and an optional CMake path for Linux learners. Git's default autocrlf behavior
# would let working-tree line endings drift per machine — and a bash script that
# picks up CRLF endings breaks with cryptic "\r: command not found" errors.
# These rules pin the intent once, for every clone.

# Default: treat files git detects as text normalized to LF in the repository,
# checked out with the platform default unless a rule below says otherwise.
* text=auto

# Shell scripts MUST be LF in the working tree — bash rejects CRLF.
*.sh text eol=lf

# PowerShell and Visual Studio files are conventionally CRLF on disk.
*.ps1 text eol=crlf
*.sln text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf

# Binary assets (committed tiny samples may include these) — never convert.
*.png binary
*.jpg binary
*.npy binary
*.bin binary
*.pdf binary
